# Database
# Local example:
# DATABASE_URL="postgresql://user:password@localhost:5432/social_network"
# Production/Vercel example:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
DATABASE_URL="postgresql://user:password@localhost:5432/social_network"

# JWT Secret
JWT_SECRET="replace-with-a-long-random-secret-at-least-32-characters"

# Node Environment
NODE_ENV="development"

# API URLs
# Optional in production for this app because relative API calls are supported.
# If you set it, use your deployed site URL.
NEXT_PUBLIC_API_URL="http://localhost:3000"

# Email (for onboarding notifications)
EMAIL_SERVICE="gmail"
EMAIL_USER="your-email@gmail.com"
EMAIL_PASSWORD="your-app-password"
